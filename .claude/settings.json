{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_tool_guard.py"
            ],
            "timeout": 30,
            "statusMessage": "Vex güvenlik politikası denetleniyor"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/task_completed.py"
            ],
            "timeout": 1200,
            "statusMessage": "Vex kalite kontrolleri çalışıyor"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|agent_needs_input|agent_completed",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/notification_hook.py"
            ],
            "timeout": 15
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "head"
  }
}
