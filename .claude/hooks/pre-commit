#!/bin/bash
# DEPRECATED: Replaced by task_completed.py. Not registered in Claude settings.
# Pre-commit hook for Vex project
# Runs verification checks before allowing commit

set -euo pipefail

ROOT="/Users/mert/Vex"
BACKEND="$ROOT/vex-backend"
FRONTEND="$ROOT/vex-app"

echo "🔍 Running pre-commit checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=0

# Function to run check
run_check() {
    local name="$1"
    local cmd="$2"
    echo -n "  $name... "
    if eval "$cmd" >/dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
        return 0
    else
        echo -e "${RED}✗${NC}"
        FAILED=1
        return 1
    fi
}

# Git diff checks
echo "Git checks:"
run_check "No whitespace errors" "git -C $ROOT diff --check"
run_check "Diff stat within budget (≤3 files, ≤150 lines)" "git -C $ROOT diff --stat | awk -F'[ ,]' '/files? changed/ {if (\$1 > 3) exit 1; if (\$4+0 > 150) exit 1}'"

# Secret scanning
echo "Security:"
run_check "No secrets in diff" "! git -C $ROOT diff | grep -iE 'api[_-]?key|secret|token|password|credential' | grep -v 'your.*here\|placeholder'"

# Backend checks (if backend files changed)
if git -C $ROOT diff --name-only | grep -q '^vex-backend/'; then
    echo "Backend:"
    cd "$BACKEND"
    run_check "Python syntax" "source .venv/bin/activate && python -m py_compile app/**/*.py"
    run_check "Unit tests" "source .venv/bin/activate && python -m unittest discover -s app/tests -v"
fi

# Frontend checks (if frontend files changed)
if git -C $ROOT diff --name-only | grep -q '^vex-app/'; then
    echo "Frontend:"
    cd "$FRONTEND"
    run_check "TypeScript build" "npm run build"
    if [ -f package.json ] && grep -q '"lint"' package.json; then
        run_check "Lint" "npm run lint"
    fi
fi

# Tauri checks (if Rust files changed)
if git -C $ROOT diff --name-only | grep -q '^vex-app/src-tauri/'; then
    echo "Tauri/Rust:"
    cd "$FRONTEND/src-tauri"
    run_check "Cargo check" "cargo check"
fi

if [ $FAILED -eq 0 ]; then
    echo -e "\n${GREEN}✅ All pre-commit checks passed${NC}"
    exit 0
else
    echo -e "\n${RED}❌ Pre-commit checks failed${NC}"
    echo "Fix issues above or use 'git commit --no-verify' to bypass (not recommended)"
    exit 1
fi